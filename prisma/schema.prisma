// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Crafter {
  id            String             @id @default(cuid())
  name          String
  characterName String
  createdAt     DateTime           @default(now())
  entries       ConsumableEntry[]
  payments      Payment[]
}

model ConsumableEntry {
  id          String          @id @default(cuid())
  crafterId   String
  crafter     Crafter         @relation(fields: [crafterId], references: [id])
  itemName    String
  itemType    ItemType        @default(OTHER)
  quantity    Int
  costPerUnit Float
  totalCost   Float
  craftedAt   DateTime        @default(now())
  raidDate    DateTime?
  status      ItemStatus      @default(AVAILABLE)
  notes       String?
  uses        ConsumableUse[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ConsumableUse {
  id        String          @id @default(cuid())
  entryId   String
  entry     ConsumableEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  unitIndex Int
  status    ItemStatus      @default(AVAILABLE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model PriceConfig {
  id            String   @id @default(cuid())
  itemType      ItemType
  price         Float
  effectiveDate DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
}

model Payment {
  id        String   @id @default(cuid())
  crafterId String
  crafter   Crafter  @relation(fields: [crafterId], references: [id])
  amount    Float
  paidAt    DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
}

enum ItemType {
  FLASK_CAULDRON
  POTION_CAULDRON
  FEAST
  VANTUS_RUNE
  OTHER
}

enum ItemStatus {
  AVAILABLE
  USED
  WASTED
}
