// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Crafter {
  id            String       @id @default(cuid())
  name          String
  characterName String
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  batches       CraftBatch[]
  usageLogs     UsageLog[]
}

// One record per crafting session
model CraftBatch {
  id          String      @id @default(cuid())
  crafterId   String
  crafter     Crafter     @relation(fields: [crafterId], references: [id])
  itemType    ItemType
  itemName    String
  quantity    Int
  costPerUnit Float
  craftedAt   DateTime    @default(now())
  notes       String?
  paidAmount  Float       @default(0)
  usageLines  UsageLine[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// One record per raid-night usage event
model UsageLog {
  id           String      @id @default(cuid())
  raidDate     DateTime
  itemType     ItemType
  itemName     String?
  quantityUsed Int
  notes        String?
  crafterId    String?
  crafter      Crafter?    @relation(fields: [crafterId], references: [id])
  lines        UsageLine[]
  createdAt    DateTime    @default(now())
}

// FIFO attribution — links a UsageLog to one or more CraftBatches
model UsageLine {
  id           String     @id @default(cuid())
  usageLogId   String
  usageLog     UsageLog   @relation(fields: [usageLogId], references: [id], onDelete: Cascade)
  batchId      String
  batch        CraftBatch @relation(fields: [batchId], references: [id])
  quantity     Int
  costPerUnit  Float      // snapshot from CraftBatch at time of attribution
  createdAt    DateTime   @default(now())
}

model PriceConfig {
  id            String   @id @default(cuid())
  itemType      ItemType
  price         Float
  effectiveDate DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
}

model NotePreset {
  id        String   @id @default(cuid())
  label     String
  createdAt DateTime @default(now())
}

enum ItemType {
  FLASK_CAULDRON
  POTION_CAULDRON
  FEAST
  VANTUS_RUNE
  OTHER
}
